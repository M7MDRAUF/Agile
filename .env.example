# AgileForge environment variables
# Copy to ".env" and adjust as needed. The defaults work for local development.

# SQLite database location (relative to the prisma/ directory).
DATABASE_URL="file:./dev.db"

# Secret used to sign session JWTs. MUST be overridden in production with a
# long random value, e.g. `openssl rand -base64 48`.
AUTH_SECRET="change-me-to-a-long-random-string"

# Default password applied to all seeded demo accounts.
SEED_PASSWORD="Password123!"
